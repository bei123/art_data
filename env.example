# 环境变量模板：复制为仓库根目录的 .env 使用（Vite 相关项也可写入 .env.development）
# 数据库配置
DB_HOST=localhost
DB_USER=data
DB_PASSWORD=your_database_password_here
DB_NAME=data

# Redis（utils/redisClient.js；库号等在代码中配置）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# 按 pattern 批量删缓存时 SCAN 的 COUNT hint（50~1000，默认 200）；生产勿用 KEYS
# REDIS_SCAN_COUNT=200
# 淘汰策略：列表类缓存用 setEx 设 TTL；详情/单键在业务写入时 del；Redis 服务端 maxmemory-policy 请在实例上单独配置（如 allkeys-lru）

# 浏览器跨域：在代码默认白名单之外追加允许的 Origin（逗号分隔，勿加引号）
# 例：CORS_ORIGINS=https://admin.example.com,https://staging.example.com
# CORS_ORIGINS=

# JWT配置
JWT_SECRET=your_very_strong_jwt_secret_key_here_at_least_32_characters

# 微信小程序配置
WX_APPID=wx96a502c78c9156d0
WX_SECRET=your_wechat_secret_here
# 微信物流助手（addOrder）：默认客户编码 / 小程序订单页路径（可选，占位符 {order_id} {out_trade_no}）
# WX_LOGISTICS_DEFAULT_BIZ_ID=
# WX_LOGISTICS_DEFAULT_WXA_PATH=/pages/orders/detail?id={order_id}

# 阿里云OSS配置
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET=your_oss_bucket_name
OSS_REGION=your_oss_region

# 阿里云OCR服务配置（用于身份证识别）
ALIBABA_CLOUD_ACCESS_KEY_ID=your_aliyun_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_aliyun_access_key_secret

# 微信支付配置
WX_PAY_MCH_ID=1360639602
WX_PAY_KEY=your_wx_pay_key_here
WX_PAY_SERIAL_NO=34DF8EA1B52AD35997FF23DFAD7940574A1D6857
WX_PUB_ID=PUB_KEY_ID_0113606396022025041900441636000800

# 阿里云身份证识别配置
ALIYUN_IDCARD_AUTHCODE=your_aliyun_authcode_here

# 对外 API 与 OSS 浏览器域名（后端：config/publicEnv.js；可不配则按 NODE_ENV 使用代码内默认）
# PUBLIC_API_BASE_URL=https://api.wx.2000gallery.art:2000
# OSS_PUBLIC_ORIGIN=https://wx.oss.2000gallery.art

# 前端 Vite（见 src/config.js；生产构建写入 .env.production）
# 独立 API 域名（需 CDN 回源 Node:2000 且允许 OPTIONS，见 deploy/CDN-API-CORS.md）：
# VITE_PUBLIC_API_BASE_URL=https://api.wx.2000gallery.art
# 备选：管理台同源反代 /api 时用 same-origin（见 deploy/nginx-admin.example.conf）
# VITE_PUBLIC_API_BASE_URL=same-origin
# VITE_OSS_PUBLIC_ORIGIN=https://wx.oss.2000gallery.art
# VITE_DEV_PROXY_TARGET=https://api.wx.2000gallery.art:2000

# 服务器配置
PORT=2000
NODE_ENV=production

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# 验证码服务配置
VERIFICATION_CODE_AUTHORIZATION=Basic d2VzcGFjZTp3ZXNwYWNlLXNlY3JldA==